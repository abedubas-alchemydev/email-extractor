# =============================================================================
# Email Extractor — backend environment template
# =============================================================================
# Loaded SECOND by app/core/config.py (override=True), so values here win over
# the root .env. Put backend-only values (API keys, rate limits) here. Shared
# values (DATABASE_URL, BACKEND_CORS_ORIGINS) typically live in the root .env
# but can be overridden here when needed.
#
# Copy this file to backend/.env and fill in real values for local dev.
# =============================================================================

# Optional: override the root DATABASE_URL when running tests against a separate DB.
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/email_extractor

# Optional: override CORS origins for backend-only experiments.
# BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Standalone Bearer auth -------------------------------------------------
# When set, every /api/v1/* request requires `Authorization: Bearer <key>`.
# When blank, the require_access dependency allows all requests (dev mode).
EMAIL_EXTRACTOR_API_KEY=

# --- Discovery provider API keys --------------------------------------------
# All optional. Coverage degrades gracefully without them.
HUNTER_API_KEY=
APOLLO_API_KEY=
SNOV_API_KEY=
