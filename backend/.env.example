# =============================================================================
# Email Extractor — backend environment template
# =============================================================================
# Loaded SECOND by app/core/config.py (override=True), so values here win over
# the root .env. Put backend-only values (API keys, rate limits) here. Shared
# values (DATABASE_URL, BACKEND_CORS_ORIGINS) typically live in the root .env
# but can be overridden here when needed.
#
# Copy this file to backend/.env and fill in real values for local dev.
# =============================================================================

# Optional: override the root DATABASE_URL when running tests against a separate DB.
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/email_extractor

# Optional: override CORS origins for backend-only experiments.
# BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Standalone Bearer auth -------------------------------------------------
# When set, every /api/v1/* request requires `Authorization: Bearer <key>`.
# When blank, the require_access dependency allows all requests (dev mode).
EMAIL_EXTRACTOR_API_KEY=

# --- Discovery provider API keys --------------------------------------------
# All optional. Coverage degrades gracefully without them.
HUNTER_API_KEY=
APOLLO_API_KEY=
SNOV_API_KEY=

# --- Provider tuning ---------------------------------------------------------
# Hunter domain-search result cap per call. Free tier: 10 (default). Paid tier:
# up to 100. Hunter returns HTTP 400 if this exceeds the plan max, so leave it
# at 10 unless you've upgraded the plan. Validated 1..100 at app startup.
HUNTER_LIMIT=10

# theHarvester OSINT sources — comma-separated, free OSINT only (no API keys).
# Defaults to crtsh,rapiddns,otx,duckduckgo. Override to add/remove sources.
# THEHARVESTER_SOURCES=crtsh,rapiddns,otx,duckduckgo

# theHarvester subprocess timeout in seconds. Validated 10..300 at app startup.
# THEHARVESTER_TIMEOUT_SECONDS=90

# --- Snov.io -----------------------------------------------------------------
# OAuth2 client_credentials flow — both client id and secret required for any
# Snov call. Leave both blank to disable (provider returns "credentials not
# configured" bare error and the rest of the discovery pipeline keeps working).
SNOV_CLIENT_ID=
SNOV_CLIENT_SECRET=

# Snov domain-emails-with-info per-call cap. Free tier typically allows up to
# 100 emails per call; paid tiers go higher. Validated 1..1000 at app startup.
SNOV_LIMIT=100
