# =============================================================================
# Email Extractor — root environment template
# =============================================================================
# Two-file env precedence (mirrors fis-lead-gen):
#   1. This root .env is loaded first (override=False).
#   2. backend/.env is loaded second (override=True) and wins on conflict.
# Shared values (DB URL, CORS) live here. Backend-only API keys live in
# backend/.env.example. The frontend reads its public env from frontend/.env.example.
#
# Copy this file to .env and fill in real values for local dev.
# =============================================================================

# --- Database ----------------------------------------------------------------
# Runtime DSN used by both SQLAlchemy's async engine AND Alembic's sync engine.
# psycopg[binary] (v3) serves both modes from the same postgresql+psycopg:// URL.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/email_extractor

# --- CORS --------------------------------------------------------------------
# Comma-separated list of origins allowed to call the backend. Frontend dev
# server runs at http://localhost:3000.
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Standalone auth ---------------------------------------------------------
# Optional Bearer token for the standalone phase. Leave blank during scaffold;
# when set, every request to /api/v1/* must send `Authorization: Bearer <key>`.
# Replaced by BetterAuth session dependency on merge into fis-lead-gen.
EMAIL_EXTRACTOR_API_KEY=

# --- Discovery provider API keys --------------------------------------------
# All optional during scaffold phase. Coverage degrades gracefully:
#   - Hunter.io is the primary paid provider.
#   - Apollo.io is secondary (generous free tier).
#   - Snov.io is tertiary.
# Without any of these, discovery falls back to in-house site crawling +
# theHarvester OSINT only.
HUNTER_API_KEY=
APOLLO_API_KEY=
SNOV_API_KEY=

# --- Postgres container creds (used by docker-compose.yml) ------------------
# These are read by the postgres service in docker-compose.yml. They must
# match the user/password in DATABASE_URL above.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=email_extractor

# --- Docker Compose host ports ----------------------------------------------
# FRONTEND_HOST_PORT controls the host-side port bound by the frontend service
# in docker-compose.yml. Container-internal port is always 3000.
# Default 3000 matches a fresh local dev environment. Override to 3010 (or any
# free port) on hosts where 3000 is already taken — e.g. the shared VPS at
# 76.13.22.110 where a co-tenant owns 3000.
FRONTEND_HOST_PORT=3000
