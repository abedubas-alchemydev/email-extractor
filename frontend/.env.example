# =============================================================================
# Email Extractor frontend — environment template
# =============================================================================
# Copy to frontend/.env.local for local dev. Only NEXT_PUBLIC_* vars are
# embedded into the client bundle at build time. Never put secrets here.
# =============================================================================

# Base URL for the backend API. Standalone dev: http://localhost:8000.
# After merge into fis-lead-gen, leave blank so the BFF proxy at
# app/api/backend/[...path]/route.ts handles routing.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
